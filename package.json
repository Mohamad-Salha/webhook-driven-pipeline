{
	"name": "webhook-driven-pipeline",
	"version": "1.0.0",
	"description": "A webhook-driven task processing pipeline.",
	"main": "dist/api/index.js",
	"scripts": {
		"build": "tsc",
		"start": "node dist/api/index.js",
		"start:worker": "node dist/worker/index.js",
		"dev": "tsx watch src/api/index.ts",
		"dev:worker": "tsx watch src/worker/index.ts",
		"dev:all": "concurrently \"npm:dev\" \"npm:dev:worker\"",
		"lint": "eslint .",
		"test": "echo \"Error: no test specified\" && exit 1",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"generate": "drizzle-kit generate",
		"migrate": "drizzle-kit migrate"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Mohamad-Salha/webhook-driven-pipeline.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"bugs": {
		"url": "https://github.com/Mohamad-Salha/webhook-driven-pipeline/issues"
	},
	"homepage": "https://github.com/Mohamad-Salha/webhook-driven-pipeline#readme",
	"devDependencies": {
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.20.0",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.57.1",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.1.0",
		"nodemon": "^3.1.14",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"express": "^5.2.1",
		"pg": "^8.20.0"
	}
}